generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model ContactSubmission {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String
  message   String
  createdAt DateTime @default(now())

  @@map("contact_submissions")
}

model ProjectView {
  id        String   @id @default(cuid())
  slug      String   @unique
  count     Int      @default(0)
  updatedAt DateTime @updatedAt

  @@map("project_views")
}

model BlogView {
  id        String   @id @default(cuid())
  slug      String   @unique
  count     Int      @default(0)
  updatedAt DateTime @updatedAt

  @@map("blog_views")
}
